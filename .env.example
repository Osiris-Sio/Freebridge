# .env.example - Modèle de configuration pour Freebridge
# Copiez ce fichier et renommez-le en '.env' pour votre configuration locale.

# --- Configuration Base de Données ---
DB_HOST=localhost
DB_NAME=votre_base_de_données
DB_USER=votre_utilisateur
DB_PASS=votre_mot_de_passe

# --- Configuration PayPal (IDs de boutons) ---
PAYPAL_BUTTON_ID_PROGRESSER=ID_BOUTON_ICI
PAYPAL_BUTTON_ID_PEAUFINER=ID_BOUTON_ICI
PAYPAL_BUTTON_ID_CONFIRMER=ID_BOUTON_ICI
PAYPAL_UNSUBSCRIBE_ALIAS=ALIAS_DESABONNEMENT

# --- Configuration Emails ---
CONTACT_EMAIL_BERNARD=email@exemple.com
NO_REPLY_EMAIL=no-reply@votre-domaine.fr
WEBMASTER_EMAIL=webmaster@exemple.com
